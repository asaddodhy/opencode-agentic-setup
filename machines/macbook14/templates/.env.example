# Telegram bot configuration
# Get token from @BotFather, user ID from @userinfobot
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_numeric_user_id_here

# OpenCode server (default: http://localhost:4096)
OPENCODE_API_URL=http://localhost:4096

# Model to use for responses
OPENCODE_MODEL_PROVIDER=opencode
OPENCODE_MODEL_ID=deepseek-v4-flash-free

# Optional settings
BOT_LOCALE=en
RESPONSE_STREAMING=true
OPENCODE_AUTO_RESTART_ENABLED=true

# Server auth
OPENCODE_SERVER_PASSWORD=your_strong_password_here
OPENCODE_SERVER_USERNAME=opencode

# Voice transcription follow-up prompt for OpenCode
# The transcription is sent as "[Voice note: <text>]\n\n<VOICE_FOLLOWUP_PROMPT>"
# Set to empty to send only the raw transcription (no follow-up)
VOICE_FOLLOWUP_PROMPT=What should I do with this transcription?

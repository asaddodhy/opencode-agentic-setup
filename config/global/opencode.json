{
  "$schema": "https://opencode.ai/config.json",
  "provider": {
    "perp": {
      "name": "Perplexity Web",
      "npm": "@ai-sdk/openai-compatible",
      "options": {
        "baseURL": "http://localhost:8002/v1",
        "apiKey": "${PERPLEXITY_SESSION_TOKEN}"
      },
      "models": {
        "perplexity/best": { "name": "Perplexity Best" },
        "perplexity/deep-research": { "name": "Deep Research" },
        "perplexity/sonar-2": { "name": "Sonar 2" },
        "openai/gpt-5.4": { "name": "GPT-5.4" },
        "openai/gpt-5.4-thinking": { "name": "GPT-5.4 Thinking" },
        "openai/gpt-5.5-thinking": { "name": "GPT-5.5 Thinking" },
        "google/gemini-3.1-pro-thinking-low": { "name": "Gemini 3.1 Pro Thinking Low" },
        "google/gemini-3.1-pro-thinking-high": { "name": "Gemini 3.1 Pro Thinking High" },
        "anthropic/claude-sonnet-4.6": { "name": "Claude Sonnet 4.6" },
        "anthropic/claude-sonnet-4.6-thinking": { "name": "Claude Sonnet 4.6 Thinking" },
        "anthropic/claude-opus-4.7": { "name": "Claude Opus 4.7" },
        "anthropic/claude-opus-4.7-thinking": { "name": "Claude Opus 4.7 Thinking" },
        "moonshot/kimi-k2.6-instant": { "name": "Kimi K2.6 Instant" },
        "moonshot/kimi-k2.6-thinking": { "name": "Kimi K2.6 Thinking" },
        "nvidia/nemotron-3-super-thinking": { "name": "Nemotron 3 Super Thinking" }
      }
    }
  },
  "mcp": {
    "perplexity": {
      "type": "local",
      "command": [
        "uvx",
        "--from",
        "perplexity-webui-scraper[mcp]@latest",
        "perplexity-webui-scraper",
        "mcp"
      ],
      "enabled": true,
      "env": {
        "PERPLEXITY_SESSION_TOKEN": "${PERPLEXITY_SESSION_TOKEN}"
      }
    }
  }
}

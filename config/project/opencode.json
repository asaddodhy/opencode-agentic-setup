{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "description": "Alfred — Dev team lead: orchestrates, delegates, drives completion",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/prompts/alfred.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "prometheus": {
      "description": "Strategic planner — interviews, analyzes, creates plans (read-only)",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/prompts/prometheus.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "deny",
        "edit": "deny",
        "bash": "deny",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "atlas": {
      "description": "Todo orchestrator — systematically executes plans, delegates to subagents",
      "mode": "primary",
      "prompt": "{file:~/.config/opencode/prompts/atlas.txt}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "task": "allow",
        "edit": "ask",
        "bash": "ask",
        "webfetch": "allow",
        "websearch": "allow"
      }
    },
    "michael": {
      "description": "General coding specialist — features, implementation",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/prompts/michael.txt}",
      "temperature": 0.3,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "ask"
      }
    },
    "michael-quick": {
      "description": "Quick-fix coder — minimal changes, fast turnaround",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/prompts/michael-quick.txt}",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "ask"
      }
    },
    "michael-deep": {
      "description": "Deep architecture specialist — refactoring, complex work",
      "mode": "subagent",
      "prompt": "{file:~/.config/opencode/prompts/michael-deep.txt}",
      "temperature": 0.2,
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "ask"
      }
    }
  }
}

# Telegram bot configuration
# 1. Create a bot via @BotFather on Telegram and get the token
# 2. Get your numeric user ID from @userinfobot
# 3. Fill in the values below
# 4. Rename this file to .env

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_ALLOWED_USER_ID=your_numeric_user_id_here

# OpenCode server (default: http://localhost:4096)
OPENCODE_API_URL=http://localhost:4096

# Model to use for responses
OPENCODE_MODEL_ID=deepseek-v4-flash-free

# Optional settings
BOT_LOCALE=en
RESPONSE_STREAMING=true
OPENCODE_AUTO_RESTART_ENABLED=true

# Server auth (if required by your OpenCode setup)
# OPENCODE_SERVER_PASSWORD=
# OPENCODE_SERVER_USERNAME=opencode
